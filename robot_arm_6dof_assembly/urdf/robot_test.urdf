<?xml version="1.0" encoding="utf-8"?>
<!-- Fixed for ROS2 compatibility (per Vorlesung 1_Modelling):
     - World-Frame mit Z-up Korrektur (CAD: +Y up -> World: +Z up)
     - Robot name: knickarm_6dof
     - joint_2 bis joint_5: fixed -> revolute (Exporter-Fehler korrigiert)
     - Alle Axis-Nullvektoren -> "0 0 1" (DH-Konvention)
     - Joint Limits, Effort, Velocity befüllt
     - Dynamics (damping/friction) ergänzt
     - joint_tcp: Nullvektor-Axis entfernt
     - Material names befüllt
     - HINWEIS: 6 bewegliche Joints (joint_1 bis joint_6) -> echter 6DOF Knickarm!
-->
<robot name="knickarm_6dof">

  <!-- World Frame mit Z-up Korrektur für SolidWorks-Export -->
  <link name="world" />
  <joint name="world_to_base" type="fixed">
    <parent link="world" />
    <child link="base_link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0.0 0.058842 0.0" rpy="0 0 0" />
      <mass value="10.856" />
      <inertia
        ixx="0.056123"  ixy="0.0"  ixz="0.0"
        iyy="0.064497"  iyz="0.0"
        izz="0.056123" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///mnt/c/Users/Raini/Desktop/FH/Master/2/ROD/robot_arm_6dof/robot_arm_6dof_assembly/meshes/base_link.STL" />
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///mnt/c/Users/Raini/Desktop/FH/Master/2/ROD/robot_arm_6dof/robot_arm_6dof_assembly/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="link_1">
    <inertial>
      <origin xyz="0.0 0.070484 0.0" rpy="0 0 0" />
      <mass value="7.3362" />
      <inertia
        ixx="0.023594"  ixy="0.0"  ixz="0.0"
        iyy="0.022891"  iyz="0.0"
        izz="0.022929" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///mnt/c/Users/Raini/Desktop/FH/Master/2/ROD/robot_arm_6dof/robot_arm_6dof_assembly/meshes/link_1.STL" />
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///mnt/c/Users/Raini/Desktop/FH/Master/2/ROD/robot_arm_6dof/robot_arm_6dof_assembly/meshes/link_1.STL" />
      </geometry>
    </collision>
  </link>

  <!-- Joint 1: Basis-Drehung -->
  <joint name="joint_1" type="revolute">
    <origin xyz="0 0 0.15" rpy="1.5708 0 1.5708" />
    <parent link="base_link" />
    <child link="link_1" />
    <axis xyz="0 1 0" />
    <limit lower="-3.1416" upper="3.1416" effort="300.0" velocity="1.571" />
    <dynamics damping="2.0" friction="1.0" />
  </joint>

  <link name="link_2">
    <inertial>
      <origin xyz="0.0 0.0 0.39" rpy="0 0 0" />
      <mass value="12.577" />
      <inertia
        ixx="1.0467"  ixy="0.0"  ixz="0.0"
        iyy="0.9886"  iyz="0.0"
        izz="0.094901" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///mnt/c/Users/Raini/Desktop/FH/Master/2/ROD/robot_arm_6dof/robot_arm_6dof_assembly/meshes/link_2.STL" />
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///mnt/c/Users/Raini/Desktop/FH/Master/2/ROD/robot_arm_6dof/robot_arm_6dof_assembly/meshes/link_2.STL" />
      </geometry>
    </collision>
  </link>

  <!-- Joint 2: Schulter (war fixed im Export!) -->
  <joint name="joint_2" type="revolute">
    <origin xyz="0 0.09 0" rpy="1.5708 0 3.1416" />
    <parent link="link_1" />
    <child link="link_2" />
    <axis xyz="0 1 0" />
    <limit lower="-3.1416" upper="3.1416" effort="300.0" velocity="1.571" />
    <dynamics damping="2.0" friction="1.0" />
  </joint>

  <link name="link_3">
    <inertial>
      <origin xyz="-0.15486 0.0 0.0" rpy="0 0 0" />
      <mass value="5.0111" />
      <inertia
        ixx="0.017184"  ixy="0.0"  ixz="0.0"
        iyy="0.10451"   iyz="0.0"
        izz="0.10804" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///mnt/c/Users/Raini/Desktop/FH/Master/2/ROD/robot_arm_6dof/robot_arm_6dof_assembly/meshes/link_3.STL" />
      </geometry>
      <material name="olive">
        <color rgba="0.5 0.5 0 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///mnt/c/Users/Raini/Desktop/FH/Master/2/ROD/robot_arm_6dof/robot_arm_6dof_assembly/meshes/link_3.STL" />
      </geometry>
    </collision>
  </link>

  <!-- Joint 3: Ellbogen (war fixed im Export!) -->
  <joint name="joint_3" type="revolute">
    <origin xyz="0 0 0.78" rpy="0 1.5708 0" />
    <parent link="link_2" />
    <child link="link_3" />
    <axis xyz="0 1 0" />
    <limit lower="-3.1416" upper="3.1416" effort="150.0" velocity="1.571" />
    <dynamics damping="1.0" friction="0.5" />
  </joint>

  <link name="link_4">
    <inertial>
      <origin xyz="-0.062648 0.0 0.0" rpy="0 0 0" />
      <mass value="2.8147" />
      <inertia
        ixx="0.016383"  ixy="0.0"  ixz="0.0"
        iyy="0.010718"  iyz="0.0"
        izz="0.022619" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///mnt/c/Users/Raini/Desktop/FH/Master/2/ROD/robot_arm_6dof/robot_arm_6dof_assembly/meshes/link_4.STL" />
      </geometry>
      <material name="teal">
        <color rgba="0 0.5 0.5 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///mnt/c/Users/Raini/Desktop/FH/Master/2/ROD/robot_arm_6dof/robot_arm_6dof_assembly/meshes/link_4.STL" />
      </geometry>
    </collision>
  </link>

  <!-- Joint 4: Wrist 1 (war fixed im Export!) -->
  <joint name="joint_4" type="revolute">
    <origin xyz="-0.32 0 0" rpy="0 0 0" />
    <parent link="link_3" />
    <child link="link_4" />
    <axis xyz="0 1 0" />
    <limit lower="-3.1416" upper="3.1416" effort="50.0" velocity="3.142" />
    <dynamics damping="0.5" friction="0.2" />
  </joint>

  <link name="link_5">
    <inertial>
      <origin xyz="0.0 0.073741 -0.0073233" rpy="0 0 0" />
      <mass value="2.305" />
      <inertia
        ixx="0.0061277"  ixy="0.0"  ixz="0.0"
        iyy="0.003854"   iyz="0.00038988"
        izz="0.0054633" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///mnt/c/Users/Raini/Desktop/FH/Master/2/ROD/robot_arm_6dof/robot_arm_6dof_assembly/meshes/link_5.STL" />
      </geometry>
      <material name="purple">
        <color rgba="0.5 0 0.5 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///mnt/c/Users/Raini/Desktop/FH/Master/2/ROD/robot_arm_6dof/robot_arm_6dof_assembly/meshes/link_5.STL" />
      </geometry>
    </collision>
  </link>

  <!-- Joint 5: Wrist 2 (war fixed im Export!) -->
  <joint name="joint_5" type="revolute">
    <origin xyz="-0.17 0 0" rpy="3.1416 0 -1.5708" />
    <parent link="link_4" />
    <child link="link_5" />
    <axis xyz="0 1 0" />
    <limit lower="-3.1416" upper="3.1416" effort="30.0" velocity="3.142" />
    <dynamics damping="0.3" friction="0.1" />
  </joint>

  <link name="tool">
    <inertial>
      <origin xyz="0.0 -0.0089196 -0.031888" rpy="0 0 0" />
      <mass value="1.5393" />
      <inertia
        ixx="0.003164"   ixy="0.0"  ixz="0.0"
        iyy="0.0037725"  iyz="2.9223E-05"
        izz="0.0010376" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///mnt/c/Users/Raini/Desktop/FH/Master/2/ROD/robot_arm_6dof/robot_arm_6dof_assembly/meshes/tool.STL" />
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///mnt/c/Users/Raini/Desktop/FH/Master/2/ROD/robot_arm_6dof/robot_arm_6dof_assembly/meshes/tool.STL" />
      </geometry>
    </collision>
  </link>

  <!-- Joint 6: Tool-Rotation (war fixed im Export!) -->
  <joint name="joint_6" type="revolute">
    <origin xyz="0 0.095 -0.115" rpy="-1.5708 0 3.1416" />
    <parent link="link_5" />
    <child link="tool" />
    <axis xyz="0 1 0" />
    <limit lower="-3.1416" upper="3.1416" effort="20.0" velocity="3.142" />
    <dynamics damping="0.2" friction="0.05" />
  </joint>

</robot>
